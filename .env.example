# NEO — Meter Defect Analysis Agent
# Copy this file to .env and fill in the values for your chosen provider.

# ── Provider selection ─────────────────────────────────────────────────────────
# Set to 'azure' to start with Azure OpenAI, or leave as 'bedrock' (default).
# You can also switch at runtime using the /connect command in the TUI.
AI_PROVIDER=bedrock

# ── AWS Bedrock ────────────────────────────────────────────────────────────────
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ── Azure OpenAI ───────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/openai/v1
AZURE_MODEL_ID=gpt-4o
